---
import { profile } from '../data/profile';
import { THEMES } from '../lib/themes';
import { WORDMARKS } from '../lib/wordmarks';
import AboutBlock from './AboutBlock.astro';
import ContactBlock from './ContactBlock.astro';
import FooterBlock from './FooterBlock.astro';
import { firstPublicAsset, heroArtCandidates } from '../lib/assets';
import { withBase } from '../lib/base';

const t = THEMES.razer;
// drop-in: add public/assets/hero/razer.{webp,jpg,png} and it appears behind the hero automatically
const heroArt = firstPublicAsset(heroArtCandidates('razer'));
// count-up only where the metric is a clean number
const cu = (v: string) => {
  const n = parseFloat(v.replace(/[^0-9.]/g, ''));
  if (!isFinite(n) || /[A-Za-z]/.test(v.replace(/^[^0-9]*/, '').replace(/[^A-Za-z]/g, ''))) return null;
  return { n, prefix: v.trim().startsWith('$') ? '$' : '', suffix: /\+$/.test(v.trim()) ? '+' : '' };
};
---
<div id="gm-boot" data-theme="razer" data-dur="1500" style="background:#040404">
  <div class="rz-boot">
    <div class="rz-boot-scan" aria-hidden="true"></div>
    <div class="rz-boot-txt">CHROMA ENABLED</div>
  </div>
</div>

<div id="razerSweep" aria-hidden="true"></div>
<div class="fx rz-grid" id="razerGrid" aria-hidden="true"></div>

<main class="rz-wrap">
  <section class="rz-hero">
    {heroArt && (
      <div class="rz-hero-art" aria-hidden="true" style={`background-image:url('${withBase(heroArt)}')`}></div>
    )}
    <p class="rz-kicker rv">{t.copy.kicker}</p>
    <div class="rz-wordmark rv"><span class="rz-wordmark-inner" data-glitch set:html={WORDMARKS.razer}></span></div>
    <p class="rz-banner rv">{t.copy.banner}</p>
    <p class="rz-lede rv">{t.copy.lede}</p>

    <div class="rz-hud rv" aria-hidden="true">
      <span>SYSTEM: <b>ONLINE</b></span><span>CHROMA: <b>ON</b></span><span>PING: <b>12ms</b></span><span>OPERATOR: <b>1</b></span>
    </div>

    <div class="rz-bench">
      {profile.heroStats.map((s) => {
        const c = cu(s.value);
        return (
          <div class="rz-bench-cell rv">
            {c ? <div class="v" data-countup={String(c.n)} data-prefix={c.prefix} data-suffix={c.suffix}>{s.value}</div>
               : <div class="v">{s.value}</div>}
            <div class="l">{s.label}{s.selfReported && <span class="rz-star">*</span>}</div>
          </div>
        );
      })}
    </div>
    <div class="rz-cta rv">
      <a class="rz-btn" href="#rz-specs">{t.copy.cta1}</a>
      <a class="rz-btn ghost" href={`mailto:${profile.identity.contact.email}`}>{t.copy.cta2}</a>
    </div>
  </section>

  <h2 class="rz-h2 rv" id="rz-specs"><span>//</span> {t.copy.teamTitle}</h2>
  <div class="rz-specs">
    {profile.team.map((m) => {
      const c = cu(m.metric);
      return (
        <article class="rz-spec rv" data-hot style={`--w:${m.level}%`}>
          <div class="rz-spec-top"><span class="rz-label">{t.copy.cardLabel}</span><span class="rz-led"></span></div>
          <div class="rz-role">{m.role}</div>
          <h3>{m.headline}{m.selfReported && <span class="rz-star">*</span>}</h3>
          <p>{m.detail}</p>
          <div class="rz-val">{c ? <b data-countup={String(c.n)} data-prefix={c.prefix} data-suffix={c.suffix}>{m.metric}</b> : <b>{m.metric}</b>}<span>{m.metricLabel}</span></div>
          <div class="rz-bar"><i></i></div>
        </article>
      );
    })}
  </div>

  <h2 class="rz-h2 rv"><span>//</span> {t.copy.flagTitle}</h2>
  <div class="rz-modules">
    {profile.flagships.map((f) => (
      <article class="rz-module rv" data-hot>
        <div class="rz-mod-head"><span class="rz-led"></span><span class="rz-status">INSTALLED</span><span class="rz-mod-tag">{f.tag}</span></div>
        <h4>{f.name}</h4>
        <div class="rz-stack">{f.stack}</div>
        <p>{f.detail}</p>
        <ul>{f.metrics.map((x) => <li>{x}</li>)}</ul>
      </article>
    ))}
  </div>

  <AboutBlock /><ContactBlock /><FooterBlock />
</main>

<style is:global>
  [data-theme="razer"] body { background: #080808; }
  [data-theme="razer"] .gm-section-title { display: none; }

  .rz-boot { position: relative; width: 100%; height: 100%; display: grid; place-items: center; }
  .rz-boot-scan { position: absolute; inset: 0; background: repeating-linear-gradient(0deg, rgba(68,214,44,.10) 0 2px, transparent 2px 5px); }
  .rz-boot-scan::after { content: ""; position: absolute; left: 0; right: 0; height: 3px; background: #44D62C; box-shadow: 0 0 22px #44D62C; animation: rz-power 1.2s ease forwards; }
  .rz-boot-txt { position: relative; font-family: 'Chakra Petch', sans-serif; font-weight: 700; letter-spacing: .3em; color: #44D62C; font-size: clamp(20px, 5vw, 40px); text-shadow: 0 0 24px rgba(68,214,44,.7); opacity: 0; animation: rz-flash .5s ease .5s forwards; }
  @keyframes rz-power { 0% { top: 0; } 100% { top: 100%; } }
  @keyframes rz-flash { 0% { opacity: 0; } 30% { opacity: 1; } 45% { opacity: .3; } 60% { opacity: 1; } 100% { opacity: 1; } }

  #razerSweep { position: fixed; left: 0; right: 0; top: var(--dock-h); height: 3px; z-index: 150;
    background: linear-gradient(90deg, #00e5ff, #44D62C, #ff2bd6, #44D62C, #00e5ff); background-size: 300% 100%;
    animation: gm-chroma 4s linear infinite; box-shadow: 0 0 18px rgba(68,214,44,.7); }
  @keyframes gm-chroma { 0% { background-position: 0% 0; } 100% { background-position: 300% 0; } }

  .rz-grid { z-index: 0; background:
      linear-gradient(rgba(68,214,44,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(68,214,44,.055) 1px, transparent 1px);
    background-size: 46px 46px; }

  .rz-wrap { max-width: 1160px; margin: 0 auto; padding: 80px 22px 120px; position: relative; z-index: 2; }
  .rz-hero { position: relative; padding: 20px 0 10px; overflow: hidden; }
  .rz-hero > :not(.rz-hero-art) { position: relative; z-index: 1; }
  .rz-hero-art { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
    background-size: cover; background-position: right center; }
  .rz-hero-art::before { content: ""; position: absolute; inset: 0;
    background: linear-gradient(90deg, #080808 0%, #080808 40%, rgba(8,8,8,.55) 60%, transparent 75%); }
  .rz-hero-art::after { content: ""; position: absolute; inset: 0;
    background:
      linear-gradient(0deg, #080808 0%, transparent 32%),
      linear-gradient(180deg, #080808 0%, transparent 18%),
      linear-gradient(270deg, #080808 0%, transparent 14%); }
  .rz-kicker { color: #44D62C; font-family: 'Share Tech Mono', monospace; letter-spacing: .18em; font-size: 13px; margin-bottom: 14px; }
  .rz-wordmark { position: relative; }
  .rz-wordmark-inner { display: inline-block; position: relative; }
  .rz-wordmark .wm { width: min(560px, 84vw); height: auto; filter: drop-shadow(0 0 30px rgba(68,214,44,.4)); }
  .rz-wordmark-inner[data-glitch].on { animation: gm-glitch .32s steps(2) 2; }
  @keyframes gm-glitch { 0% { transform: translate(0,0); filter: none; } 25% { transform: translate(-2px,1px); filter: drop-shadow(2px 0 #00E0FF) drop-shadow(-2px 0 #ff2bd6); } 50% { transform: translate(2px,-1px); } 75% { transform: translate(-1px,0); filter: drop-shadow(-2px 0 #00E0FF); } 100% { transform: none; filter: none; } }
  .rz-banner { font-family: 'Chakra Petch'; text-transform: uppercase; letter-spacing: .06em; color: #cfcfcf; font-size: clamp(15px, 2.2vw, 20px); margin: 8px 0 10px; }
  .rz-lede { color: #8f8f8f; max-width: 620px; line-height: 1.55; font-size: clamp(15px, 2vw, 18px); }
  .rz-hud { display: flex; gap: 18px; flex-wrap: wrap; margin: 20px 0; font-family: 'Share Tech Mono', monospace; font-size: 12px; color: #8a8a8a; letter-spacing: .08em; }
  .rz-hud b { color: #44D62C; }
  .rz-bench { display: flex; gap: 14px; flex-wrap: wrap; margin: 8px 0 6px; }
  .rz-bench-cell { border: 1px solid #1c1c1c; background: #0d0d0d; padding: 14px 22px; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%); min-width: 150px; }
  .rz-bench-cell .v { font-family: 'Chakra Petch'; font-weight: 700; font-size: 30px; color: #44D62C; text-shadow: 0 0 18px rgba(68,214,44,.5); animation: rz-pulse 2.6s ease-in-out infinite; }
  .rz-bench-cell .l { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #7d7d7d; text-transform: uppercase; letter-spacing: .06em; margin-top: 6px; }
  .rz-star { color: #00E0FF; }
  @keyframes rz-pulse { 0%,100% { text-shadow: 0 0 14px rgba(68,214,44,.4); } 50% { text-shadow: 0 0 26px rgba(68,214,44,.85); } }

  .rz-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 22px; }
  .rz-btn { font-family: 'Chakra Petch'; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: 12px 26px; background: #44D62C; color: #041007; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%); transition: transform .15s, box-shadow .2s; }
  .rz-btn.ghost { background: transparent; border: 1px solid #3a3a3a; color: #ededed; box-shadow: inset 0 0 0 1px rgba(68,214,44,.18); }
  .rz-btn:hover { transform: translateY(-2px); box-shadow: 0 0 22px rgba(68,214,44,.5); }
  .rz-btn.ghost:hover { box-shadow: inset 0 0 0 1px rgba(68,214,44,.35), 0 0 22px rgba(68,214,44,.35); }
  .rz-btn:active { transform: scale(.98); }

  .rz-h2 { font-family: 'Chakra Petch'; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #ededed; font-size: clamp(20px, 3vw, 30px); margin: 66px 0 20px; }
  .rz-h2 span { color: #44D62C; }

  .rz-specs { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr)); gap: 16px; }
  .rz-spec { position: relative; background: #0e0e0e; border: 1px solid #242424; padding: 18px; overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%); transition: transform .25s, box-shadow .25s; }
  .rz-spec::before { content: ""; position: absolute; inset: 0; padding: 1px; pointer-events: none; opacity: 0;
    background: linear-gradient(120deg, #44D62C, #00E0FF, #44D62C) border-box; background-size: 200% 100%;
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; transition: opacity .25s; }
  .rz-spec:hover, .rz-spec:focus-within { transform: translateY(-4px); box-shadow: 0 0 28px rgba(68,214,44,.28); }
  .rz-spec:hover::before, .rz-spec:focus-within::before { opacity: 1; animation: rz-trace 1.1s linear infinite; }
  .rz-spec:active { transform: scale(.99); }
  @keyframes rz-trace { to { background-position: 200% 0; } }
  .rz-spec-top { display: flex; justify-content: space-between; align-items: center; }
  .rz-label { font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: .2em; color: #44D62C; }
  .rz-led { width: 9px; height: 9px; border-radius: 50%; background: #44D62C; box-shadow: 0 0 10px #44D62C; animation: rz-pulse 2s ease-in-out infinite; }
  .rz-role { font-family: 'Share Tech Mono', monospace; color: #7d7d7d; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; margin-top: 8px; }
  .rz-spec h3 { font-family: 'Chakra Petch'; font-weight: 700; text-transform: uppercase; color: #ededed; font-size: 18px; margin: 4px 0 6px; }
  .rz-spec p { color: #8f8f8f; font-size: 13px; line-height: 1.5; }
  .rz-val { display: flex; align-items: baseline; gap: 8px; margin-top: 12px; }
  .rz-val b { font-family: 'Chakra Petch'; font-weight: 700; font-size: 24px; color: #44D62C; text-shadow: 0 0 16px rgba(68,214,44,.5); }
  .rz-val span { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #7d7d7d; text-transform: uppercase; }
  .rz-bar { height: 6px; background: #1a1a1a; border-radius: 2px; margin-top: 12px; overflow: hidden; }
  .rz-bar i { display: block; height: 100%; width: 0; background: linear-gradient(90deg, #44D62C, #00E0FF); box-shadow: 0 0 12px rgba(68,214,44,.6); transition: width 1.2s var(--ease); }
  .rz-spec.in .rz-bar i { width: var(--w); }

  .rz-modules { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr)); gap: 16px; }
  .rz-module { background: #0e0e0e; border: 1px solid #242424; border-left: 2px solid #44D62C; padding: 18px; transition: transform .25s, box-shadow .25s; }
  .rz-module:hover, .rz-module:focus-within { transform: translateY(-4px); box-shadow: 0 0 24px rgba(68,214,44,.22); }
  .rz-module:active { transform: scale(.99); }
  .rz-mod-head { display: flex; align-items: center; gap: 10px; }
  .rz-status { font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: .18em; color: #44D62C; }
  .rz-mod-tag { margin-left: auto; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: #7d7d7d; border: 1px solid #222; padding: 1px 7px; }
  .rz-module h4 { font-family: 'Chakra Petch'; font-weight: 700; text-transform: uppercase; color: #ededed; font-size: 17px; margin: 12px 0 4px; }
  .rz-stack { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #00E0FF; margin-bottom: 8px; }
  .rz-module p { color: #8f8f8f; font-size: 13px; line-height: 1.5; }
  .rz-module ul { list-style: none; margin-top: 10px; display: flex; flex-direction: column; gap: 5px; }
  .rz-module li { color: #cfcfcf; font-size: 12.5px; } .rz-module li::before { content: "▸ "; color: #44D62C; }

  /* ---- Touch parity: signature hover effects promoted for coarse pointers ---- */
  @media (hover: hover) and (pointer: fine) {
    .rz-spec:hover, .rz-spec:focus-within { transform: translateY(-4px); }
    .rz-module:hover, .rz-module:focus-within { transform: translateY(-4px); }
  }
  @media (hover: none), (pointer: coarse) {
    /* keep the animated trace border visible so touch users see the signature effect */
    .rz-spec::before { opacity: .55; animation: rz-trace 2.4s linear infinite; }
    /* neutralise hover lifts so nothing feels stuck in a raised state */
    .rz-spec:hover, .rz-spec:focus-within,
    .rz-module:hover, .rz-module:focus-within { transform: none; }
    /* bigger tap targets on coarse pointers */
    .rz-btn { padding: 15px 26px; }
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .rz-wrap { padding: 96px 16px 90px; }
    .rz-hero { padding: 8px 0 6px; }
    .rz-specs, .rz-modules { grid-template-columns: 1fr; }
    .rz-bench { gap: 10px; }
    .rz-bench-cell { min-width: 0; flex: 1 1 45%; padding: 12px 16px; }
    .rz-bench-cell .v { font-size: 24px; }
    .rz-h2 { margin: 44px 0 16px; }
    /* drop the heaviest FX on small screens */
    .rz-grid { display: none !important; }
  }
  @media (max-width: 380px) {
    .rz-wrap { padding-top: 104px; }
    .rz-bench-cell { flex: 1 1 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    #razerSweep, .rz-bench-cell .v, .rz-led { animation: none !important; }
    .rz-grid { display: none !important; }
    .rz-spec:hover::before, .rz-spec:focus-within::before, .rz-spec::before { animation: none !important; }
    .rz-wordmark-inner[data-glitch].on { animation: none !important; }
  }
</style>

<script>
  (function razer() {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;
    const grid = document.getElementById('razerGrid');
    // outer wrapper carries the scroll-parallax translate; inner span carries the glitch
    const wordmark = document.querySelector<HTMLElement>('.rz-wordmark');
    const mark = document.querySelector<HTMLElement>('.rz-wordmark-inner[data-glitch]');

    // scroll-parallax only on precise pointers and roomy viewports
    const coarse = matchMedia('(pointer: coarse)').matches;
    if (!coarse && innerWidth >= 720) {
      let ticking = false;
      addEventListener('scroll', () => {
        if (ticking) return; ticking = true;
        requestAnimationFrame(() => {
          const y = scrollY;
          if (grid) grid.style.transform = `translate3d(0, ${y * 0.25}px, 0)`;
          if (wordmark) wordmark.style.transform = `translate3d(0, ${y * 0.1}px, 0)`;
          ticking = false;
        });
      }, { passive: true });
    }

    // occasional glitch flicker on the wordmark (independent of scroll transform)
    if (mark) {
      let alive = true;
      const glitch = () => {
        if (!alive || !document.body.contains(mark)) { alive = false; return; }
        mark.classList.add('on');
        setTimeout(() => mark.classList.remove('on'), 340);
        setTimeout(glitch, 4200 + Math.random() * 4200);
      };
      setTimeout(glitch, 2600);
    }
  })();
</script>
