---
import { profile } from '../data/profile';
import { THEMES } from '../lib/themes';
import { WORDMARKS } from '../lib/wordmarks';
import AboutBlock from './AboutBlock.astro';
import ContactBlock from './ContactBlock.astro';
import FooterBlock from './FooterBlock.astro';

const t = THEMES.disney;
const covers = ['#1a3a8a', '#7a3f9e', '#b07a1f', '#2a7a8a', '#8a2a5a', '#3a5aaa'];
---
<div id="gm-boot" data-theme="disney" data-dur="2400" style="background:radial-gradient(circle at 50% 74%, #17225f, #060a22 72%)">
  <canvas id="disneyFw" class="dz-fw" aria-hidden="true"></canvas>
  <div class="dz-boot">
    <svg class="dz-arc" viewBox="0 0 600 240" aria-hidden="true">
      <path class="dz-arc-path" d="M40,210 Q300,20 560,210" fill="none" stroke="#E8C87A" stroke-width="3" />
    </svg>
    <svg class="dz-castle" viewBox="0 0 300 120" aria-hidden="true">
      <path d="M20,120 V70 h14 V56 h10 V70 h20 V44 h6 l6-10 6,10 h6 V70 h20 V56 h10 V70 h14 v-6 h18 V50 l10-14 10,14 v14 h18 v50 Z" fill="#0a0e2a" stroke="#26306f" stroke-width="1.5"/>
    </svg>
    <div class="dz-boot-txt">Mohamed <span>Originals</span></div>
  </div>
</div>

<canvas id="disneyStars" class="fx dz-stars" aria-hidden="true"></canvas>

<header class="dz-billboard">
  <div class="dz-billboard-inner">
    <p class="dz-kicker rv"><span aria-hidden="true">✦</span> {t.copy.kicker} <span aria-hidden="true">✦</span></p>
    <div class="dz-wordmark rv" data-float set:html={WORDMARKS.disney}></div>
    <p class="dz-banner rv">{profile.identity.tagline}</p>
    <p class="dz-logline rv">{t.copy.lede}</p>
    <div class="dz-rating rv"><span class="dz-stars-row" aria-hidden="true">✦✦✦✦✦</span> · {profile.heroLine}</div>
    <div class="dz-cta rv">
      <a class="dz-btn play" href="#dz-originals"><span aria-hidden="true">▶</span> Play</a>
      <a class="dz-btn add" href={`mailto:${profile.identity.contact.email}`}>+ Watchlist</a>
    </div>
  </div>
</header>

<div class="dz-curtain" aria-hidden="true"></div>

<main class="dz-wrap">
  <h2 class="dz-h2 rv" id="dz-originals">{t.copy.teamTitle}</h2>
  <div class="dz-row">
    {profile.team.map((m, i) => (
      <article class={`dz-poster rv d${(i % 5) + 1}`}>
        <div class="dz-cover" style={`--c1:${covers[i % covers.length]}`}>
          <span class="dz-orig-badge">✦ {t.copy.cardLabel}</span>
          <span class="dz-cover-role">{m.role}</span>
        </div>
        <div class="dz-poster-body">
          <h3>{m.headline}{m.selfReported && <span class="dz-star">*</span>}</h3>
          <p>{m.detail}</p>
          <div class="dz-meta"><b>{m.metric}</b> {m.metricLabel}</div>
        </div>
      </article>
    ))}
  </div>

  <h2 class="dz-h2 rv">{t.copy.flagTitle}</h2>
  <div class="dz-row dz-row--series">
    {profile.flagships.map((f, i) => (
      <article class={`dz-series rv d${(i % 5) + 1}`}>
        <div class="dz-cover dz-cover--series" style={`--c1:${covers[(i + 2) % covers.length]}`}>
          <span class="dz-orig-badge">✦ {t.copy.flagLabel}</span>
          <span class="dz-cover-role">{f.name}</span>
        </div>
        <div class="dz-poster-body">
          <div class="dz-season">Season 1 · Shipped · {f.tag}</div>
          <div class="dz-stack">{f.stack}</div>
          <p>{f.detail}</p>
          <ul>{f.metrics.map((x) => <li>{x}</li>)}</ul>
        </div>
      </article>
    ))}
  </div>

  <AboutBlock /><ContactBlock /><FooterBlock />
</main>

<style is:global>
  [data-theme="disney"] body { background: radial-gradient(circle at 25% 8%, #1c2a8a, #0a0e2a 62%); }
  [data-theme="disney"] .gm-section-title { display: none; }

  /* boot */
  .dz-fw { position: absolute; inset: 0; width: 100%; height: 100%; }
  .dz-boot { position: relative; text-align: center; }
  .dz-arc { width: min(560px, 86vw); height: auto; display: block; margin: 0 auto -30px; }
  .dz-arc-path { stroke-dasharray: 900; stroke-dashoffset: 900; filter: drop-shadow(0 0 10px rgba(232,200,122,.8)); animation: gm-arcsweep 1.5s ease .2s forwards; }
  @keyframes gm-arcsweep { to { stroke-dashoffset: 0; } }
  .dz-castle { width: min(300px, 60vw); height: auto; opacity: 0; animation: gm-castle 1s ease .8s forwards; }
  @keyframes gm-castle { to { opacity: 1; } }
  .dz-boot-txt { font-family: 'Cinzel', serif; font-weight: 800; color: #f5f7ff; font-size: clamp(24px, 6vw, 46px); letter-spacing: .06em; margin-top: 10px; opacity: 0; animation: gm-fadeup .9s ease 1.2s forwards; }
  .dz-boot-txt span { color: #E8C87A; }

  .dz-stars { z-index: 0; }

  .dz-billboard { position: relative; z-index: 2; min-height: 86vh; display: flex; align-items: center; padding: 70px 0 30px; }
  .dz-billboard-inner { max-width: 1200px; width: 100%; margin: 0 auto; padding: 0 clamp(20px, 5vw, 56px); }
  .dz-kicker { color: #E8C87A; font-family: 'Mulish'; font-weight: 700; letter-spacing: .28em; font-size: 13px; margin-bottom: 16px; }
  .dz-wordmark .wm { width: min(560px, 84vw); height: auto; filter: drop-shadow(0 0 34px rgba(0,168,225,.5)); }
  .dz-banner { font-family: 'Cinzel', serif; color: #f5f7ff; font-size: clamp(19px, 3vw, 30px); margin: 12px 0 10px; }
  .dz-logline { color: #b9c1ec; font-size: clamp(15px, 2vw, 19px); max-width: 620px; line-height: 1.6; }
  .dz-rating { color: #d7ddf7; font-size: 14px; margin: 18px 0; } .dz-stars-row { color: #E8C87A; letter-spacing: 2px; }
  .dz-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .dz-btn { font-family: 'Mulish'; font-weight: 700; padding: 13px 30px; border-radius: 8px; font-size: 16px; transition: transform .15s, box-shadow .2s; }
  .dz-btn.play { background: #fff; color: #0a0e2a; } .dz-btn.play:hover { box-shadow: 0 0 30px rgba(0,168,225,.6); }
  .dz-btn.add { background: rgba(255,255,255,.12); color: #fff; border: 1px solid #3a4790; }
  .dz-btn:hover { transform: translateY(-2px); }
  .dz-btn:active { transform: translateY(0) scale(.97); }

  .dz-curtain { position: relative; z-index: 2; height: 3px; background: linear-gradient(90deg, transparent, #E8C87A, transparent); margin: 0 auto; max-width: 90%; box-shadow: 0 0 20px rgba(232,200,122,.5); }

  .dz-wrap { max-width: 1220px; margin: 0 auto; padding: 30px clamp(20px, 5vw, 56px) 120px; position: relative; z-index: 2; }
  .dz-h2 { font-family: 'Cinzel', serif; font-weight: 700; color: #f5f7ff; font-size: clamp(22px, 3.4vw, 34px); margin: 50px 0 22px; }
  .dz-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr)); gap: 20px; }
  .dz-poster, .dz-series { position: relative; background: linear-gradient(160deg, #141a44, #0d1235); border: 1px solid #26306f; border-radius: 16px; overflow: hidden; transition: transform .3s var(--ease), box-shadow .3s, border-color .3s; }
  .dz-poster:hover, .dz-series:hover, .dz-poster:focus-visible, .dz-series:focus-visible, .dz-poster:focus-within, .dz-series:focus-within { transform: translateY(-8px); border-color: #E8C87A; box-shadow: 0 22px 54px rgba(0,168,225,.3); }
  .dz-poster:focus-visible, .dz-series:focus-visible { outline: 2px solid #E8C87A; outline-offset: 3px; }
  .dz-poster:active, .dz-series:active { transform: translateY(-4px) scale(.99); }
  .dz-cover { position: relative; height: 150px; display: flex; flex-direction: column; justify-content: space-between; padding: 14px; overflow: hidden;
    background: radial-gradient(120% 100% at 30% 20%, color-mix(in srgb, var(--c1) 85%, #fff 0%), #0a0e2a 92%); }
  .dz-cover--series { height: 132px; }
  .dz-orig-badge { align-self: flex-start; font-family: 'Mulish'; font-weight: 700; font-size: 10px; letter-spacing: .12em; color: #0a0e2a; background: #E8C87A; padding: 2px 8px; border-radius: 4px; }
  .dz-cover-role { font-family: 'Cinzel', serif; font-weight: 700; color: #fff; font-size: 20px; text-shadow: 0 2px 12px rgba(0,0,0,.5); }
  /* gold shimmer-swipe on reveal */
  .dz-poster.in .dz-cover::after, .dz-series.in .dz-cover::after {
    content: ""; position: absolute; top: 0; left: -70%; width: 60%; height: 100%;
    background: linear-gradient(100deg, transparent, rgba(232,200,122,.65), transparent); animation: gm-shim 1.1s ease .1s forwards; }
  @keyframes gm-shim { to { left: 130%; } }
  .dz-poster-body { padding: 16px 18px 18px; }
  .dz-poster-body h3 { font-family: 'Cinzel', serif; font-weight: 700; color: #f5f7ff; font-size: 16px; margin-bottom: 6px; line-height: 1.25; }
  .dz-star { color: #E8C87A; }
  .dz-poster-body p { color: #b9c1ec; font-size: 13px; line-height: 1.55; }
  .dz-meta { margin-top: 12px; color: #d7ddf7; font-size: 13px; } .dz-meta b { font-family: 'Cinzel'; color: #00A8E1; font-size: 20px; }
  .dz-season { font-family: 'Mulish'; font-weight: 700; color: #E8C87A; font-size: 12px; letter-spacing: .04em; margin-bottom: 4px; }
  .dz-stack { font-family: 'Mulish'; font-size: 12px; color: #7f8bc9; margin-bottom: 8px; }
  .dz-series ul { list-style: none; margin-top: 10px; display: flex; flex-direction: column; gap: 5px; } .dz-series li { color: #d7ddf7; font-size: 12.5px; } .dz-series li::before { content: "✦ "; color: #E8C87A; }

  /* staggered poster reveals */
  .dz-poster.d1, .dz-series.d1 { transition-delay: .04s; }
  .dz-poster.d2, .dz-series.d2 { transition-delay: .12s; }
  .dz-poster.d3, .dz-series.d3 { transition-delay: .2s; }
  .dz-poster.d4, .dz-series.d4 { transition-delay: .28s; }
  .dz-poster.d5, .dz-series.d5 { transition-delay: .36s; }

  /* touch parity: hover lift/glow only where a real pointer exists */
  @media (hover: hover) and (pointer: fine) {
    .dz-poster:hover, .dz-series:hover { transform: translateY(-8px); }
    .dz-btn.play:hover { box-shadow: 0 0 30px rgba(0,168,225,.6); }
  }
  @media (hover: none), (pointer: coarse) {
    /* signature shimmer must not depend on hover — keep it visible on reveal */
    .dz-poster.in .dz-cover::after, .dz-series.in .dz-cover::after { overflow: visible; }
    .dz-poster:hover, .dz-series:hover, .dz-poster:active, .dz-series:active { transform: none; }
    /* larger tap targets */
    .dz-btn { padding: 15px 30px; min-height: 44px; display: inline-flex; align-items: center; justify-content: center; }
  }

  /* responsive */
  @media (max-width: 640px) {
    .dz-billboard { min-height: auto; padding: 96px 0 24px; }
    .dz-billboard-inner { padding: 0 20px; }
    .dz-wordmark .wm { filter: drop-shadow(0 0 18px rgba(0,168,225,.5)); }
    .dz-row { grid-template-columns: 1fr; }
    .dz-cover { height: 120px; }
    .dz-wrap { padding: 24px 20px 84px; }
    .dz-h2 { margin: 34px 0 18px; }
    /* drop the heaviest background FX on small screens */
    .dz-stars, .dz-fw { display: none !important; }
    .dz-btn { width: 100%; }
  }
  @media (max-width: 480px) {
    .dz-billboard { padding: 88px 0 20px; }
    .dz-logline { font-size: 15px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dz-stars, .dz-fw { display: none !important; }
    .dz-arc-path, .dz-castle, .dz-boot-txt { animation: none !important; opacity: 1; stroke-dashoffset: 0; }
    .dz-poster.in .dz-cover::after, .dz-series.in .dz-cover::after { display: none; }
    .dz-poster.d1, .dz-series.d1, .dz-poster.d2, .dz-series.d2, .dz-poster.d3, .dz-series.d3,
    .dz-poster.d4, .dz-series.d4, .dz-poster.d5, .dz-series.d5 { transition-delay: 0s; }
  }
</style>

<script>
  (function disney() {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    // starfield parallax
    const cv = document.getElementById('disneyStars') as HTMLCanvasElement | null;
    if (cv) {
      const ctx = cv.getContext('2d')!;
      let stars: { x: number; y: number; r: number; s: number; tw: number }[] = [];
      let sy = 0, run = true, visible = true, looping = false;
      let lastW = innerWidth;
      const build = () => {
        cv.width = innerWidth; cv.height = innerHeight;
        const COUNT = innerWidth < 700 ? 46 : innerWidth < 1100 ? 90 : 150;
        stars = Array.from({ length: COUNT }, () => ({ x: Math.random() * cv.width, y: Math.random() * cv.height, r: Math.random() * 1.7 + 0.2, s: Math.random() * 0.4 + 0.08, tw: Math.random() * 6 }));
      };
      build();
      // debounced resize; bail on tiny width deltas (mobile URL-bar show/hide)
      let rt: number | undefined;
      addEventListener('resize', () => {
        clearTimeout(rt);
        rt = window.setTimeout(() => {
          if (Math.abs(innerWidth - lastW) < 40) { cv.height = innerHeight; return; }
          lastW = innerWidth; build();
        }, 150);
      });
      addEventListener('scroll', () => { sy = scrollY; }, { passive: true });
      const kick = () => { const go = run && visible; if (go && !looping) { looping = true; loop(); } };
      document.addEventListener('visibilitychange', () => { run = !document.hidden; kick(); });
      // pause the starfield when the hero leaves the viewport
      const hero = document.querySelector('.dz-billboard');
      if (hero && 'IntersectionObserver' in window) {
        new IntersectionObserver((es) => { visible = es[0].isIntersecting; kick(); }, { threshold: 0 }).observe(hero);
      }
      function loop() {
        if (!run || !visible || !cv || !document.body.contains(cv)) { looping = false; return; }
        ctx.clearRect(0, 0, cv.width, cv.height);
        for (const st of stars) {
          st.tw += 0.05;
          const py = (st.y - sy * 0.15 * st.s * 3) % cv.height;
          const yy = (py + cv.height) % cv.height;
          ctx.globalAlpha = 0.4 + Math.sin(st.tw) * 0.4;
          ctx.fillStyle = st.r > 1.2 ? '#E8C87A' : '#cfe0ff';
          ctx.beginPath(); ctx.arc(st.x, yy, st.r, 0, 7); ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(loop);
      }
      kick();
    }

    // floating title parallax — skip on touch / small screens
    const allowParallax = !matchMedia('(pointer: coarse)').matches && innerWidth >= 720;
    const mark = document.querySelector<HTMLElement>('.dz-wordmark[data-float]');
    if (allowParallax && mark) {
      let ticking = false;
      addEventListener('scroll', () => {
        if (ticking) return; ticking = true;
        requestAnimationFrame(() => { mark.style.transform = `translate3d(0, ${scrollY * -0.08}px, 0)`; ticking = false; });
      }, { passive: true });
    }

    // boot fireworks — skip entirely on repeat visits
    const fw = document.getElementById('disneyFw') as HTMLCanvasElement | null;
    let seenBoot = false;
    try { seenBoot = sessionStorage.getItem('gm-dz-fw-seen') === '1'; } catch {}
    if (fw && seenBoot) { fw.remove(); }
    else if (fw) {
      const ctx = fw.getContext('2d')!;
      fw.width = innerWidth; fw.height = Math.min(innerHeight, 700);
      type P = { x: number; y: number; vx: number; vy: number; life: number; c: string };
      let parts: P[] = [];
      const colors = ['#E8C87A', '#00A8E1', '#f5f7ff', '#8ab4ff'];
      const burst = (x: number, y: number) => {
        const c = colors[Math.floor(Math.random() * colors.length)];
        for (let i = 0; i < 46; i++) {
          const a = (Math.PI * 2 * i) / 46, sp = 1.6 + Math.random() * 2.6;
          parts.push({ x, y, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp, life: 1, c });
        }
      };
      let n = 0, alive = true, raf = 0;
      const stop = () => { alive = false; if (raf) cancelAnimationFrame(raf); if (fw.isConnected) fw.remove(); };
      const fire = () => { if (!alive || !fw.isConnected) { alive = false; return; } if (n++ < 5) { burst(fw.width * (0.2 + Math.random() * 0.6), fw.height * (0.25 + Math.random() * 0.35)); setTimeout(fire, 340); } };
      setTimeout(fire, 500);
      // safety: never let the fireworks canvas linger
      const safety = setTimeout(stop, 2600);
      (function anim() {
        if (!alive || !fw.isConnected) return;
        ctx.clearRect(0, 0, fw.width, fw.height);
        parts.forEach((p) => { p.x += p.vx; p.y += p.vy; p.vy += 0.03; p.life -= 0.016; ctx.globalAlpha = Math.max(0, p.life); ctx.fillStyle = p.c; ctx.beginPath(); ctx.arc(p.x, p.y, 2, 0, 7); ctx.fill(); });
        parts = parts.filter((p) => p.life > 0);
        ctx.globalAlpha = 1;
        // stop once all bursts fired and every particle has died
        if (parts.length || n < 5) { raf = requestAnimationFrame(anim); }
        else { clearTimeout(safety); stop(); }
      })();
      try { sessionStorage.setItem('gm-dz-fw-seen', '1'); } catch {}
    }
  })();
</script>
